name: ci

on:
  workflow_dispatch:      # Permet de lancer le build manuellement
  push:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    # Remove ~18 GiB of preinstalled software to have more disk space during the build
    - name: Cleanup runner
      run: |
        df -h
        sudo rm -rf /opt/microsoft /usr/local/.ghcup /usr/local/julia* /usr/share/dotnet /usr/share/swift /usr/lib/llvm*
        df -h

    - name: Checkout repository
      uses: actions/checkout@v4
      with:
        submodules: 'recursive' # On s'assure que tous les émulateurs s'installent bien dans Docker

    - name: Set up Docker Buildx
      uses: docker/setup-buildx-action@v3

    # On modifie le build Docker pour lui dire de compiler spécifiquement pour l'ESP32-S3
    - name: Build
      uses: docker/build-push-action@v6
      with:
        context: .
        tags: retro-go:latest
        cache-from: type=gha
        cache-to: type=gha,mode=max
        load: true
        build-args: |
          TARGET=esp32-s3-devkit

    # On modifie l'extraction pour copier TOUS les formats de fichiers générés (.fw, .img, .bin)
    - name: Extract binaries from docker image
      run: |
        mkdir -p build
        docker run --rm -v $(pwd)/build:/dist retro-go:latest sh -c "cp -r /app/build/* /dist/ 2>/dev/null || cp /app/*.img /dist/ 2>/dev/null || cp /app/*.fw /dist/ 2>/dev/null"

    # On demande à GitHub de sauvegarder absolument tout ce qui a été extrait
    - name: Upload artifacts
      uses: actions/upload-artifact@v4
      with:
        name: binaries
        path: build/
